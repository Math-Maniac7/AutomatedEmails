# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/email_manager

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=change-me-to-a-256-bit-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Credential Encryption (AES-256-GCM)
# Generate: python -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=change-me-to-a-32-byte-base64url-encoded-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Gmail OAuth (Google Cloud Console -> OAuth 2.0 Credentials)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/oauth/gmail/callback

# Outlook OAuth (Azure Portal -> App Registrations)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/oauth/outlook/callback

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
